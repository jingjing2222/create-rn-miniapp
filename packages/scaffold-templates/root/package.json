{
  "name": "{{appName}}-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "nx run-many -t build --all",
    "typecheck": "nx run-many -t typecheck --all",
    "test": "nx run-many -t test --all",
    "format": "pnpm exec biome format . --write",
    "format:check": "pnpm exec biome format .",
    "lint": "pnpm exec biome lint .",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^24.10.1",
    "nx": "^22.5.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
