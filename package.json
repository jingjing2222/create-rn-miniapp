{
  "name": "create-miniapp-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "nx run-many -t build --all",
    "typecheck": "nx run-many -t typecheck --all",
    "test": "nx run-many -t test --all",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm format",
    "publish:dev": "pnpm exec tsx packages/create-rn-miniapp/src/release/dev-publish.ts",
    "release": "changeset publish",
    "format": "pnpm exec biome format . --write",
    "format:check": "pnpm exec biome format .",
    "lint": "pnpm exec biome lint .",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^24.10.1",
    "nx": "^22.0.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
